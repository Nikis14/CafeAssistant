# Copy to .env and fill in. You only need a key for the provider you actually use.

# Provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# LangSmith tracing (recommended)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=taste-agent-s7
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# External APIs (Phase 4 — not needed for the Phase 1 skeleton)
TAVILY_API_KEY=
FOURSQUARE_API_KEY=

# Set to "1" to skip the HuggingFace sentence-transformers download for
# episodic memory and use a deterministic fake embedding instead. Useful
# for offline demos. Leave unset in production.
TASTE_AGENT_FAKE_EMBEDDING=
